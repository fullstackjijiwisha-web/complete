{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/v1",
      "destination": "/api/index"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/ready",
      "destination": "/api/index"
    },
    {
      "source": "/invite/accept",
      "destination": "/Frontend/extracted/invite.html"
    },
    {
      "source": "/verify/:certId",
      "destination": "/Frontend/extracted/verify.html"
    },
    {
      "source": "/",
      "destination": "/Frontend/extracted/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/Frontend/extracted/:path*"
    }
  ]
}