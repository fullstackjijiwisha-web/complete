# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/posh_compass
# Production: mongodb+srv://<user>:<pass>@cluster.mongodb.net/posh_compass (Atlas Mumbai / ap-south-1)

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend URL / CORS ───────────────────────────────────────────────────
# Set FRONTEND_DIR to serve the static site from this API (same origin —
# required by the SameSite=Strict refresh cookie). CLIENT_URL is used in
# emailed links, so it must be the served site's origin.
CLIENT_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5000
FRONTEND_DIR=../Frontend/extracted

# ── Encryption (sensitive third-party tokens at rest) ─────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex

# ── Email (Nodemailer — leave unset in dev to log emails to console) ──────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_smtp_api_key
EMAIL_FROM=noreply@jijiwishasociety.org

# ── Monitoring (optional) ─────────────────────────────────────────────────
SENTRY_DSN=

# ── Bootstrap super admin (optional; created at startup if missing) ───────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ── Domain thresholds (platform constants — Super Admin only) ─────────────
CERT_PASS_THRESHOLD=80
ORG_READY_THRESHOLD=95
ATTEMPT_TIME_LIMIT_MIN=60
MAX_ATTEMPTS_PER_CYCLE=3

# ── Paper composition (v1 default: 50 questions) ──────────────────────────
PAPER_MCQ_COUNT=30
PAPER_FIB_COUNT=0
PAPER_CASE_COUNT=0
PAPER_SIM_COUNT=0

# ── Payments (Razorpay — leave unset in dev to disable the payment gate) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Certificates / verification ───────────────────────────────────────────
CERT_VERIFY_BASE_URL=http://localhost:5173/verify
CERT_SIGNING_SECRET=replace_with_64_char_hex

# ── Public stats cache ─────────────────────────────────────────────────────
PUBLIC_STATS_CACHE_TTL_SEC=600
