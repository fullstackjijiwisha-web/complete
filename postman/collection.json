{
  "info": {
    "name": "POSH Compass API",
    "description": "P0 run order per Blueprint §10: register-org → login → me → enrol employee → roster → refresh → logout → me(401). No real secrets in this file.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 · Register organisation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.expect(json.success).to.be.true;",
              "pm.environment.set('accessToken', json.data.accessToken);",
              "pm.environment.set('orgCode', json.data.orgCode);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/register-org",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orgName\": \"ABC Pvt. Ltd.\",\n  \"headcount\": 1240,\n  \"adminName\": \"HR Admin\",\n  \"email\": \"hr@example.com\",\n  \"password\": \"changeme-strong-1\"\n}"
        }
      }
    },
    {
      "name": "02 · Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.environment.set('accessToken', json.data.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"hr@example.com\",\n  \"password\": \"changeme-strong-1\"\n}"
        }
      }
    },
    {
      "name": "03 · GET /users/me",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/users/me"
      }
    },
    {
      "name": "04 · Enrol employee",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.environment.set('employeeId', pm.response.json().data.userId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/orgs/me/employees",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya@example.com\"\n}"
        }
      }
    },
    {
      "name": "05 · Roster",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Paginated', () => pm.expect(pm.response.json().pagination).to.exist);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/orgs/me/employees?page=1&limit=20"
      }
    },
    {
      "name": "06 · Org dashboard",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('No department field anywhere', () => {",
              "  pm.expect(JSON.stringify(pm.response.json())).to.not.match(/department/i);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/orgs/me/dashboard"
      }
    },
    {
      "name": "07 · Refresh",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.environment.set('accessToken', pm.response.json().data.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/v1/auth/refresh"
      }
    },
    {
      "name": "08 · Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/auth/logout"
      }
    },
    {
      "name": "09 · Public stats (no auth)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/public/stats"
      }
    }
  ]
}
